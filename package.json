{
    "name": "trivia-app",
    "version": "0.1.0",
    "private": true,
    "dependencies": {
        "@capacitor/android": "^8.1.0",
        "@capacitor/app": "^8.0.1",
        "@capacitor/cli": "^8.1.0",
        "@capacitor/core": "^8.1.0",
        "@capacitor/preferences": "^8.0.1",
        "@capacitor/push-notifications": "^8.0.1",
        "@capacitor/splash-screen": "^8.0.1",
        "@capacitor/status-bar": "^8.0.1",
        "@sentry/react": "^10.39.0",
        "@supabase/supabase-js": "^2.95.3",
        "papaparse": "^5.5.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-scripts": "^0.0.0",
        "recharts": "^3.7.0"
    },
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build",
        "db:migrate": "node scripts/migrate.js",
        "build:cap": "cross-env PUBLIC_URL=. react-scripts build",
        "cap:sync": "npx cap sync",
        "cap:android": "npm run build:cap && npx cap sync android && npx cap open android",
        "cap:dev": "npx cap sync android && npx cap run android"
    },
    "eslintConfig": {
        "extends": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "dotenv": "^17.3.1",
        "gh-pages": "^6.3.0",
        "pg": "^8.19.0",
        "supabase": "^2.76.15"
    },
    "homepage": "https://gstreet-ops.github.io/trivia-app"
}
